{
  "title": "Stock Market Kubeflow Pipeline",
  "uid": "stock-pipeline",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Prediction Requests",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(predictions_total)",
          "legendFormat": "Total"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API Request Rate (req/s)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total[1m]))",
          "legendFormat": "req/s"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate (req/s)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total{status=\"500\"}[1m]))",
          "legendFormat": "errors/s"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 0.01 }
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P95 Latency (s)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate by Endpoint",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(api_requests_total[1m]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Prediction Count by Model",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (model) (rate(predictions_total[1m]))",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "API Latency Percentiles",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, endpoint) (rate(api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{endpoint}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Model MSE",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "model_mse",
          "legendFormat": "{{model}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      }
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Model R² Score",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "model_r2",
          "legendFormat": "{{model}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      }
    }
  ]
}
